# Database
DATABASE_URL=postgresql+asyncpg://cortex:cortex_dev@db:5432/cortex

# Deepgram
DEEPGRAM_API_KEY=your_deepgram_key

# LLM (Groq — OpenAI compatible)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_your_groq_key
LLM_MODEL=qwen/qwen3-32b
LLM_FALLBACK_MODEL=llama-3.1-8b-instant

# Embeddings (Jina — OpenAI compatible)
EMBEDDINGS_BASE_URL=https://api.jina.ai/v1
EMBEDDINGS_API_KEY=jina_your_key
EMBEDDINGS_MODEL=jina-embeddings-v3

# Agent pipeline (LangGraph multi-agent)
AGENT_PIPELINE_ENABLED=true
SUPERVISOR_MODEL=qwen/qwen3-32b
SPECIALIST_MODEL=qwen/qwen3-32b
CONVERSATION_MODEL=llama-3.1-8b-instant
POST_MEETING_MODEL=qwen/qwen3-32b
CONFIDENCE_TECH_LEAD=0.6
CONFIDENCE_PM=0.7
CONFIDENCE_DEVELOPER=0.6
CONFIDENCE_COMMERCIAL=0.85
CONFIDENCE_ADMIN=0.5

# Auth
JWT_SECRET=your_jwt_secret_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Frontend (set to wss:// and https:// for production)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Production example:
# NEXT_PUBLIC_API_URL=https://api.cortex.secture.com
# NEXT_PUBLIC_WS_URL=wss://api.cortex.secture.com
